<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bejelentkezés — Cloudexus</title>
    <link rel="icon" href="{{ base_url }}/assets/favicon.svg" type="image/svg+xml">
    <link href="{{ base_url }}/assets/vendor/bootstrap/bootstrap.min.css" rel="stylesheet">
    <link href="{{ base_url }}/assets/vendor/bootstrap-icons/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ base_url }}/assets/css/app.css?v={{ asset_version }}">
</head>
<body class="cx-auth-body">
<div class="cx-auth-decor"></div>
<div class="cx-auth-card">
    <div class="cx-auth-card__brand">
        <span class="cx-auth-card__brand-icon"><i class="bi bi-boxes"></i></span>
        <span>Cloudexus</span>
    </div>
    <p class="cx-auth-card__subtitle">Felhő alapú ügyviteli rendszer</p>

    {% if error %}
        <div class="alert alert-danger d-flex align-items-center py-2" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{ error }}
        </div>
    {% endif %}

    <form method="post" action="{{ base_url }}/login" id="login-form">
        <input type="hidden" name="_token" value="{{ csrf_token }}">
        <input type="hidden" name="recaptcha_token" id="recaptcha_token">
        <div class="mb-3">
            <label for="username" class="form-label">Felhasználónév vagy e-mail</label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                <input type="text" id="username" name="username" class="form-control" required autofocus>
            </div>
        </div>
        <div class="mb-4">
            <label for="password" class="form-label">Jelszó</label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                <input type="password" id="password" name="password" class="form-control" required>
            </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2" id="login-submit">Belépés</button>
    </form>
</div>
</body>
{% if recaptcha_enabled %}
    <script src="https://www.google.com/recaptcha/api.js?render={{ recaptcha_site_key }}"></script>
    <script>
        (function () {
            const form = document.getElementById('login-form');
            const submitBtn = document.getElementById('login-submit');
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                submitBtn.disabled = true;
                grecaptcha.ready(function () {
                    grecaptcha.execute('{{ recaptcha_site_key }}', {action: 'login'}).then(function (token) {
                        document.getElementById('recaptcha_token').value = token;
                        form.submit();
                    });
                });
            });
        })();
    </script>
{% endif %}
</html>
