{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Tárhelyek és polcok</h2>
            <a href="{{ base_url }}/locations/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Új tárhely
            </a>
        </div>
        <div class="cx-card__body p-0">
            <form method="get" class="p-3 border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-sm-4 col-lg-3">
                        <label class="form-label small text-muted mb-1">Keresés</label>
                        <input type="text" name="q" class="form-control form-control-sm" placeholder="Helykód vagy név…" value="{{ filters.q }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Raktár</label>
                        <select name="warehouse_id" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            {% for w in warehouses %}
                                <option value="{{ w.id }}" {{ filters.warehouse_id == w.id ? 'selected' : '' }}>{{ w.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Állapot</label>
                        <select name="status" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            <option value="active" {{ filters.status == 'active' ? 'selected' : '' }}>Aktív</option>
                            <option value="inactive" {{ filters.status == 'inactive' ? 'selected' : '' }}>Inaktív</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                        <a href="{{ base_url }}/locations" class="btn btn-sm btn-outline-secondary">Törlés</a>
                    </div>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Raktár</th>
                        <th>Helykód</th>
                        <th>Megnevezés</th>
                        <th class="text-end">Készlet</th>
                        <th class="text-end">Termékféle</th>
                        <th>Állapot</th>
                        <th class="text-end">Műveletek</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for l in locations %}
                        <tr>
                            <td class="text-muted">{{ l.warehouse_name }}</td>
                            <td class="fw-medium text-nowrap">
                                <a href="{{ base_url }}/stock?location_id={{ l.id }}" class="text-decoration-none">{{ l.code }}</a>
                            </td>
                            <td>{{ l.name ?: '—' }}</td>
                            <td class="text-end">{{ l.stock_qty|number_format(0, ',', ' ') }}</td>
                            <td class="text-end text-muted">{{ l.product_count }}</td>
                            <td>
                                {% if l.is_active %}
                                    <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Aktív</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Inaktív</span>
                                {% endif %}
                            </td>
                            <td class="text-end text-nowrap">
                                <a href="{{ base_url }}/locations/{{ l.id }}/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="{{ base_url }}/locations/{{ l.id }}/delete" class="d-inline" onsubmit="return confirm('Biztosan törlöd?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő tárhely.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include 'common/pagination.twig' %}
        </div>
    </div>
{% endblock %}
