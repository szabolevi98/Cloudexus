{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Partnerek</h2>
            <div class="d-flex gap-2">
                <a href="{{ base_url }}/partners/export?{{ filters|url_encode }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-download me-1"></i>CSV export
                </a>
                <a href="{{ base_url }}/partners/create" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-lg me-1"></i>Új partner
                </a>
            </div>
        </div>
        <div class="cx-card__body p-0">
            <form method="get" class="p-3 border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-sm-4 col-lg-3">
                        <label class="form-label small text-muted mb-1">Keresés</label>
                        <input type="text" name="q" class="form-control form-control-sm" placeholder="Név, adószám vagy e-mail…" value="{{ filters.q }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Típus</label>
                        <select name="type" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            <option value="customer" {{ filters.type == 'customer' ? 'selected' : '' }}>Vevő</option>
                            <option value="supplier" {{ filters.type == 'supplier' ? 'selected' : '' }}>Szállító</option>
                            <option value="both" {{ filters.type == 'both' ? 'selected' : '' }}>Vevő + Szállító</option>
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Állapot</label>
                        <select name="status" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            <option value="active" {{ filters.status == 'active' ? 'selected' : '' }}>Aktív</option>
                            <option value="inactive" {{ filters.status == 'inactive' ? 'selected' : '' }}>Inaktív</option>
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Vevőcsoport</label>
                        <select name="customer_group_id" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            {% for g in customer_groups %}
                                <option value="{{ g.id }}" {{ filters.customer_group_id == g.id ? 'selected' : '' }}>{{ g.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                        <a href="{{ base_url }}/partners" class="btn btn-sm btn-outline-secondary">Törlés</a>
                    </div>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Név</th>
                        <th>Típus</th>
                        <th>Adószám</th>
                        <th>E-mail</th>
                        <th>Telefon</th>
                        <th>Vevőcsoport</th>
                        <th>Állapot</th>
                        <th class="text-end">Műveletek</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for partner in partners %}
                        <tr>
                            <td class="fw-medium"><a href="{{ base_url }}/partners/{{ partner.id }}" class="text-decoration-none">{{ partner.name }}</a></td>
                            <td>
                                {% if partner.type == 'customer' %}
                                    <span class="badge rounded-pill text-bg-primary">Vevő</span>
                                {% elseif partner.type == 'supplier' %}
                                    <span class="badge rounded-pill text-bg-secondary">Szállító</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-info">Vevő + Szállító</span>
                                {% endif %}
                            </td>
                            <td class="text-muted">{{ partner.tax_number ?: '—' }}</td>
                            <td class="text-muted">{{ partner.email ?: '—' }}</td>
                            <td class="text-muted">{{ partner.phone ?: '—' }}</td>
                            <td class="text-muted">{{ partner.customer_group_name ?: '—' }}</td>
                            <td>
                                {% if partner.is_active %}
                                    <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Aktív</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Inaktív</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ base_url }}/partners/{{ partner.id }}/edit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ base_url }}/partners/{{ partner.id }}/delete" class="d-inline" onsubmit="return confirm('Biztosan törlöd?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="8" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő partner.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include 'common/pagination.twig' %}
        </div>
    </div>
{% endblock %}
