{% extends 'common/layout.twig' %}

{% block content %}
    <h1>{{ user ? 'Felhasználó szerkesztése' : 'Új felhasználó' }}</h1>

    {% if errors %}
        <p class="alert alert--error">{{ errors }}</p>
    {% endif %}

    <form method="post" action="{{ base_url }}/users{{ user ? '/' ~ user.id : '/create' }}" class="form">
        <div class="form__row">
            <label for="username">Felhasználónév</label>
            <input type="text" id="username" name="username" value="{{ user.username|default('') }}" required>
        </div>
        <div class="form__row">
            <label for="email">E-mail</label>
            <input type="email" id="email" name="email" value="{{ user.email|default('') }}" required>
        </div>
        <div class="form__row">
            <label for="full_name">Teljes név</label>
            <input type="text" id="full_name" name="full_name" value="{{ user.full_name|default('') }}" required>
        </div>
        <div class="form__row">
            <label for="password">Jelszó {{ user ? '(üresen hagyva nem változik)' : '' }}</label>
            <input type="password" id="password" name="password" {{ user ? '' : 'required' }}>
        </div>
        <div class="form__row">
            <label for="role">Szerepkör</label>
            <select id="role" name="role">
                <option value="user" {{ user.role == 'user' ? 'selected' : '' }}>Felhasználó</option>
                <option value="admin" {{ user.role == 'admin' ? 'selected' : '' }}>Admin</option>
            </select>
        </div>
        <div class="form__row form__row--checkbox">
            <label>
                <input type="checkbox" name="is_active" {{ (user is null or user.is_active) ? 'checked' : '' }}>
                Aktív
            </label>
        </div>
        <button type="submit" class="btn btn--primary">Mentés</button>
        <a href="{{ base_url }}/users" class="btn">Mégse</a>
    </form>
{% endblock %}
