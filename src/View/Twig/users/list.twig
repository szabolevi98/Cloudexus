{% extends 'common/layout.twig' %}

{% block content %}
    <h1>Felhasználók</h1>

    {% if success %}
        <p class="alert alert--success">{{ success }}</p>
    {% endif %}

    <a href="{{ base_url }}/users/create" class="btn btn--primary">+ Új felhasználó</a>

    <table class="table">
        <thead>
        <tr>
            <th>Felhasználónév</th>
            <th>Név</th>
            <th>E-mail</th>
            <th>Szerepkör</th>
            <th>Aktív</th>
            <th>Utolsó belépés</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.username }}</td>
                <td>{{ user.full_name }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.role }}</td>
                <td>{{ user.is_active ? 'Igen' : 'Nem' }}</td>
                <td>{{ user.last_login_at ?: '—' }}</td>
                <td>
                    <a href="{{ base_url }}/users/{{ user.id }}/edit">Szerkesztés</a>
                    {% if user.id != auth_user_id %}
                        <form method="post" action="{{ base_url }}/users/{{ user.id }}/delete" style="display:inline" onsubmit="return confirm('Biztosan törlöd?');">
                            <button type="submit" class="link-button">Törlés</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
