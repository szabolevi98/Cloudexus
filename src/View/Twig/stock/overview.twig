{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Raktárkészlet</h2>
        </div>
        <div class="cx-card__body p-0">
            <form method="get" class="p-3 border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-sm-4 col-lg-3">
                        <label class="form-label small text-muted mb-1">Termék keresés</label>
                        <input type="text" name="q" class="form-control form-control-sm" placeholder="Cikkszám vagy megnevezés…" value="{{ filters.q }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Raktár</label>
                        <select name="warehouse_id" id="ov-warehouse" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            {% for w in warehouses %}
                                <option value="{{ w.id }}" {{ filters.warehouse_id == w.id ? 'selected' : '' }}>{{ w.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Tárhely</label>
                        <select name="location_id" id="ov-location" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            {% for l in locations %}
                                <option value="{{ l.id }}" data-warehouse="{{ l.warehouse_id }}" {{ filters.location_id == l.id ? 'selected' : '' }}>{{ l.code }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                        <a href="{{ base_url }}/stock" class="btn btn-sm btn-outline-secondary">Törlés</a>
                    </div>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Raktár</th>
                        <th>Tárhely</th>
                        <th>Cikkszám</th>
                        <th>Megnevezés</th>
                        <th class="text-end">Mennyiség</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in rows %}
                        <tr>
                            <td>{{ row.warehouse_name }}</td>
                            <td class="text-muted">{{ row.location_code ?: '—' }}</td>
                            <td class="fw-medium">{{ row.sku }}</td>
                            <td>{{ row.product_name }}</td>
                            <td class="text-end">
                                <span class="badge rounded-pill {{ row.quantity < 0 ? 'text-bg-danger-subtle text-danger-emphasis' : 'text-bg-success-subtle text-success-emphasis' }}">
                                    {{ row.quantity|number_format(0, ',', ' ') }} {{ row.unit }}
                                </span>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő készlet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include 'common/pagination.twig' %}
        </div>
    </div>

    <script>
        (function () {
            const wh = document.getElementById('ov-warehouse');
            const loc = document.getElementById('ov-location');
            function filter() {
                const w = wh.value;
                Array.from(loc.options).forEach(o => {
                    if (!o.value) return;
                    const show = !w || o.dataset.warehouse === w;
                    o.hidden = !show;
                    if (!show && o.selected) loc.value = '';
                });
            }
            wh.addEventListener('change', filter);
            filter();
        })();
    </script>
{% endblock %}
