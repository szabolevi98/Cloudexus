{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Új átadás</h2>
                </div>
                <div class="cx-card__body">
                    <form method="post" action="{{ base_url }}/stock/transfer">
                        <div class="mb-3">
                            <label for="from_warehouse_id" class="form-label">Forrásraktár</label>
                            <select id="from_warehouse_id" name="from_warehouse_id" class="form-select" required>
                                <option value="">Válassz raktárat…</option>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="to_warehouse_id" class="form-label">Célraktár</label>
                            <select id="to_warehouse_id" name="to_warehouse_id" class="form-select" required>
                                <option value="">Válassz raktárat…</option>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="product_id" class="form-label">Termék</label>
                            <select id="product_id" name="product_id" class="form-select" required>
                                <option value="">Válassz terméket…</option>
                                {% for p in products %}
                                    <option value="{{ p.id }}">{{ p.sku }} — {{ p.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="quantity" class="form-label">Mennyiség</label>
                            <input type="number" step="0.001" min="0.001" id="quantity" name="quantity" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="note" class="form-label">Megjegyzés</label>
                            <input type="text" id="note" name="note" class="form-control">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-arrow-left-right me-1"></i>Átadás rögzítése
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Legutóbbi átadások</h2>
                </div>
                <div class="cx-card__body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 cx-table">
                            <thead>
                            <tr>
                                <th>Dátum</th>
                                <th>Irány</th>
                                <th>Raktár</th>
                                <th>Termék</th>
                                <th class="text-end">Mennyiség</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for m in transfers %}
                                <tr>
                                    <td class="text-muted">{{ m.created_at }}</td>
                                    <td>
                                        {% if m.type == 'out' %}
                                            <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Kiadás</span>
                                        {% else %}
                                            <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Bevét</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ m.warehouse_name }}</td>
                                    <td>{{ m.sku }} — {{ m.product_name }}</td>
                                    <td class="text-end fw-medium {{ m.type == 'out' ? 'text-danger' : 'text-success' }}">
                                        {{ m.type == 'out' ? '-' : '+' }}{{ m.quantity|number_format(0, ',', ' ') }} {{ m.unit }}
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="5" class="text-center text-muted py-4">Még nem volt raktárközi átadás.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
