{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Új átadás</h2>
                </div>
                <div class="cx-card__body">
                    <form method="post" action="{{ base_url }}/stock/transfer">
                        <div class="mb-3">
                            <label for="from_warehouse_id" class="form-label">Forrásraktár</label>
                            <select id="from_warehouse_id" name="from_warehouse_id" class="form-select" required>
                                <option value="">Válassz raktárat…</option>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="from_location_id" class="form-label">Forrás tárhely <span class="text-muted small">(opcionális)</span></label>
                            <select id="from_location_id" name="from_location_id" class="form-select">
                                <option value="">— tárhely nélkül —</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="to_warehouse_id" class="form-label">Célraktár</label>
                            <select id="to_warehouse_id" name="to_warehouse_id" class="form-select" required>
                                <option value="">Válassz raktárat…</option>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="to_location_id" class="form-label">Cél tárhely <span class="text-muted small">(opcionális)</span></label>
                            <select id="to_location_id" name="to_location_id" class="form-select">
                                <option value="">— tárhely nélkül —</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="product_id" class="form-label">Termék</label>
                            <select id="product_id" name="product_id" class="form-select" required>
                                <option value="">Válassz terméket…</option>
                                {% for p in products %}
                                    <option value="{{ p.id }}">{{ p.sku }} — {{ p.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="quantity" class="form-label">Mennyiség</label>
                            <input type="number" step="0.001" min="0.001" id="quantity" name="quantity" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="note" class="form-label">Megjegyzés</label>
                            <input type="text" id="note" name="note" class="form-control">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-arrow-left-right me-1"></i>Átadás rögzítése
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Legutóbbi átadások</h2>
                </div>
                <div class="cx-card__body p-0">
                    <form method="get" class="p-3 border-bottom">
                        <div class="row g-2 align-items-end">
                            <div class="col-sm-4 col-lg-3">
                                <label class="form-label small text-muted mb-1">Termék</label>
                                <input type="text" name="q" class="form-control form-control-sm" placeholder="Cikkszám vagy név…" value="{{ filters.q }}">
                            </div>
                            <div class="col-sm-3 col-lg-3">
                                <label class="form-label small text-muted mb-1">Raktár</label>
                                <select name="warehouse_id" class="form-select form-select-sm">
                                    <option value="">Mind</option>
                                    {% for w in warehouses %}
                                        <option value="{{ w.id }}" {{ filters.warehouse_id == w.id ? 'selected' : '' }}>{{ w.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-sm-3 col-lg-2">
                                <label class="form-label small text-muted mb-1">Dátumtól</label>
                                <input type="date" name="date_from" class="form-control form-control-sm" value="{{ filters.date_from }}">
                            </div>
                            <div class="col-sm-3 col-lg-2">
                                <label class="form-label small text-muted mb-1">Dátumig</label>
                                <input type="date" name="date_to" class="form-control form-control-sm" value="{{ filters.date_to }}">
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                                <a href="{{ base_url }}/stock/transfer" class="btn btn-sm btn-outline-secondary">Törlés</a>
                            </div>
                        </div>
                    </form>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 cx-table">
                            <thead>
                            <tr>
                                <th>Dátum</th>
                                <th>Irány</th>
                                <th>Raktár</th>
                                <th>Tárhely</th>
                                <th>Termék</th>
                                <th class="text-end">Mennyiség</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for m in transfers %}
                                <tr>
                                    <td class="text-muted">{{ m.created_at }}</td>
                                    <td>
                                        {% if m.type == 'out' %}
                                            <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Kiadás</span>
                                        {% else %}
                                            <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Bevét</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ m.warehouse_name }}</td>
                                    <td class="text-muted">{{ m.location_code ?: '—' }}</td>
                                    <td>{{ m.sku }} — {{ m.product_name }}</td>
                                    <td class="text-end fw-medium {{ m.type == 'out' ? 'text-danger' : 'text-success' }}">
                                        {{ m.type == 'out' ? '-' : '+' }}{{ m.quantity|number_format(0, ',', ' ') }} {{ m.unit }}
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="6" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő raktárközi átadás.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% include 'common/pagination.twig' %}
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const locs = {{ locations|json_encode|raw }};
            function bind(whId, locId) {
                const wh = document.getElementById(whId);
                const loc = document.getElementById(locId);
                function fill() {
                    const w = parseInt(wh.value, 10);
                    loc.innerHTML = '<option value="">— tárhely nélkül —</option>';
                    locs.filter(l => l.warehouse_id == w).forEach(l => {
                        const o = document.createElement('option');
                        o.value = l.id; o.textContent = l.code;
                        loc.appendChild(o);
                    });
                }
                wh.addEventListener('change', fill);
                fill();
            }
            bind('from_warehouse_id', 'from_location_id');
            bind('to_warehouse_id', 'to_location_id');
        })();
    </script>
{% endblock %}
