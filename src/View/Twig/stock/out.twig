{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Új kiadás</h2>
                </div>
                <div class="cx-card__body">
                    <form method="post" action="{{ base_url }}/stock/out/create">
                        <div class="mb-3">
                            <label for="warehouse_id" class="form-label">Raktár</label>
                            <select id="warehouse_id" name="warehouse_id" class="form-select" required>
                                <option value="">Válassz raktárat…</option>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="product_id" class="form-label">Termék</label>
                            <select id="product_id" name="product_id" class="form-select" required>
                                <option value="">Válassz terméket…</option>
                                {% for p in products %}
                                    <option value="{{ p.id }}">{{ p.sku }} — {{ p.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="quantity" class="form-label">Mennyiség</label>
                            <input type="number" step="0.001" min="0" id="quantity" name="quantity" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="note" class="form-label">Megjegyzés</label>
                            <input type="text" id="note" name="note" class="form-control">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-box-arrow-up me-1"></i>Kiadás rögzítése
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Kiadások</h2>
                </div>
                <div class="cx-card__body p-0">
                    <form method="get" class="p-3 border-bottom">
                        <div class="row g-2 align-items-end">
                            <div class="col-sm-4 col-lg-3">
                                <label class="form-label small text-muted mb-1">Termék</label>
                                <input type="text" name="q" class="form-control form-control-sm" placeholder="Cikkszám vagy név…" value="{{ filters.q }}">
                            </div>
                            <div class="col-sm-3 col-lg-3">
                                <label class="form-label small text-muted mb-1">Raktár</label>
                                <select name="warehouse_id" class="form-select form-select-sm">
                                    <option value="">Mind</option>
                                    {% for w in warehouses %}
                                        <option value="{{ w.id }}" {{ filters.warehouse_id == w.id ? 'selected' : '' }}>{{ w.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                                <a href="{{ base_url }}/stock/out" class="btn btn-sm btn-outline-secondary">Törlés</a>
                            </div>
                        </div>
                    </form>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 cx-table">
                            <thead>
                            <tr>
                                <th>Dátum</th>
                                <th>Raktár</th>
                                <th>Termék</th>
                                <th class="text-end">Mennyiség</th>
                                <th>Rögzítette</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for m in movements %}
                                <tr>
                                    <td class="text-muted">{{ m.created_at }}</td>
                                    <td>{{ m.warehouse_name }}</td>
                                    <td>{{ m.sku }} — {{ m.product_name }}</td>
                                    <td class="text-end text-danger fw-medium">-{{ m.quantity|number_format(0, ',', ' ') }} {{ m.unit }}</td>
                                    <td class="text-muted">{{ m.created_by_name ?: '—' }}</td>
                                </tr>
                            {% else %}
                                <tr><td colspan="5" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő kiadás.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% include 'common/pagination.twig' %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
