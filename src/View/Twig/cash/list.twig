{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3 mb-1">
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat {{ balance >= 0 ? 'cx-stat--success' : 'cx-stat--danger' }}">
                <div class="cx-stat__icon"><i class="bi bi-cash-stack"></i></div>
                <div>
                    <div class="cx-stat__label">Aktuális pénzkészlet</div>
                    <div class="cx-stat__value">{{ balance|number_format(0, ',', ' ') }} Ft</div>
                </div>
            </div>
        </div>
    </div>

    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Pénztárbizonylatok</h2>
            <a href="{{ base_url }}/cash/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Új bizonylat
            </a>
        </div>
        <div class="cx-card__body p-0">
            <form method="get" class="p-3 border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-sm-3 col-lg-3">
                        <label class="form-label small text-muted mb-1">Keresés</label>
                        <input type="text" name="q" class="form-control form-control-sm" placeholder="Bizonylatszám, megjegyzés, partner…" value="{{ filters.q }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Típus</label>
                        <select name="type" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            <option value="bevetel" {{ filters.type == 'bevetel' ? 'selected' : '' }}>Bevétel</option>
                            <option value="kiadas" {{ filters.type == 'kiadas' ? 'selected' : '' }}>Kiadás</option>
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Dátumtól</label>
                        <input type="date" name="date_from" class="form-control form-control-sm" value="{{ filters.date_from }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Dátumig</label>
                        <input type="date" name="date_to" class="form-control form-control-sm" value="{{ filters.date_to }}">
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                        <a href="{{ base_url }}/cash" class="btn btn-sm btn-outline-secondary">Törlés</a>
                    </div>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Bizonylatszám</th>
                        <th>Típus</th>
                        <th>Partner</th>
                        <th>Kapcsolódó számla</th>
                        <th>Dátum</th>
                        <th class="text-end">Összeg</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for v in vouchers %}
                        <tr>
                            <td class="fw-medium">{{ v.voucher_number }}</td>
                            <td>
                                {% if v.type == 'bevetel' %}
                                    <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Bevétel</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Kiadás</span>
                                {% endif %}
                            </td>
                            <td>{{ v.partner_name ?: '—' }}</td>
                            <td class="text-muted">{{ v.sales_invoice_number ?: v.incoming_invoice_number ?: '—' }}</td>
                            <td class="text-muted">{{ v.voucher_date }}</td>
                            <td class="text-end {{ v.type == 'bevetel' ? 'text-success' : 'text-danger' }} fw-medium">
                                {{ v.type == 'bevetel' ? '+' : '-' }}{{ v.amount|number_format(0, ',', ' ') }} Ft
                            </td>
                            <td class="text-end">
                                <form method="post" action="{{ base_url }}/cash/{{ v.id }}/delete" onsubmit="return confirm('Biztosan törlöd?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő bizonylat.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include 'common/pagination.twig' %}
        </div>
    </div>
{% endblock %}
