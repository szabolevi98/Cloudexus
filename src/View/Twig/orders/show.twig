{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <div>
                <h2>{{ order.order_number }}</h2>
                <div class="text-muted small">{{ order.partner_name }} · {{ order.order_date }}</div>
            </div>
            <div>
                {% if order.status == 'draft' %}
                    <span class="badge rounded-pill text-bg-secondary">Piszkozat</span>
                {% elseif order.status == 'confirmed' %}
                    <span class="badge rounded-pill text-bg-primary">Visszaigazolt</span>
                {% elseif order.status == 'invoiced' %}
                    <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Számlázva</span>
                {% else %}
                    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Törölve</span>
                {% endif %}
            </div>
        </div>
        {% if order.shipping_address_id or order.billing_address_id %}
            <div class="cx-card__body border-bottom pt-3 pb-3">
                <div class="row small">
                    {% if order.shipping_address_id %}
                        <div class="col-md-6">
                            <div class="text-muted mb-1">Szállítási cím</div>
                            <div>
                                {% if order.shipping_country and order.shipping_country != 'Magyarország' %}{{ order.shipping_country }}, {% endif %}
                                {{ order.shipping_postal_code }} {{ order.shipping_city }}, {{ order.shipping_street }}
                                {% if order.shipping_note %}<div class="text-muted">{{ order.shipping_note }}</div>{% endif %}
                            </div>
                        </div>
                    {% endif %}
                    {% if order.billing_address_id %}
                        <div class="col-md-6">
                            <div class="text-muted mb-1">Számlázási cím</div>
                            <div>
                                {% if order.billing_country and order.billing_country != 'Magyarország' %}{{ order.billing_country }}, {% endif %}
                                {{ order.billing_postal_code }} {{ order.billing_city }}, {{ order.billing_street }}
                                {% if order.billing_note %}<div class="text-muted">{{ order.billing_note }}</div>{% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
        <div class="cx-card__body p-0">
            <div class="table-responsive">
                <table class="table cx-table align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Cikkszám</th>
                        <th>Megnevezés</th>
                        <th class="text-end">Mennyiség</th>
                        <th class="text-end">Egységár</th>
                        <th class="text-end">Sor összesen</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in order.items %}
                        <tr>
                            <td>{{ item.sku }}</td>
                            <td>{{ item.product_name }}</td>
                            <td class="text-end">{{ item.quantity|number_format(0, ',', ' ') }} {{ item.unit }}</td>
                            <td class="text-end">{{ item.unit_price|number_format(0, ',', ' ') }} Ft</td>
                            <td class="text-end">{{ item.line_total|number_format(0, ',', ' ') }} Ft</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                    {% if order.shipping_cost > 0 %}
                        <tr>
                            <td colspan="4" class="text-end text-muted">Szállítási költség</td>
                            <td class="text-end text-muted">{{ order.shipping_cost|number_format(0, ',', ' ') }} Ft</td>
                        </tr>
                    {% endif %}
                    {% if order.payment_cost > 0 %}
                        <tr>
                            <td colspan="4" class="text-end text-muted">Fizetési költség</td>
                            <td class="text-end text-muted">{{ order.payment_cost|number_format(0, ',', ' ') }} Ft</td>
                        </tr>
                    {% endif %}
                    <tr>
                        <td colspan="4" class="text-end fw-medium">Végösszeg</td>
                        <td class="text-end fw-bold">{{ order.total_amount|number_format(0, ',', ' ') }} Ft</td>
                    </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a href="{{ base_url }}/orders" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Vissza a listához
        </a>
        {% if order.status != 'invoiced' and order.status != 'cancelled' %}
            <a href="{{ base_url }}/invoices/create?order_id={{ order.id }}" class="btn btn-primary">
                <i class="bi bi-receipt me-1"></i>Számla készítése
            </a>
            <form method="post" action="{{ base_url }}/orders/{{ order.id }}/cancel" onsubmit="return confirm('Biztosan stornózod a rendelést?');">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-x-circle me-1"></i>Stornózás
                </button>
            </form>
        {% endif %}
    </div>
{% endblock %}
