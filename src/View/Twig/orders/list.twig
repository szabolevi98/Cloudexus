{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Vevői rendelések</h2>
            <a href="{{ base_url }}/orders/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Új rendelés
            </a>
        </div>
        <div class="cx-card__body p-0">
            <form method="get" class="p-3 border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Rendelésszám</label>
                        <input type="text" name="q" class="form-control form-control-sm" placeholder="REND-…" value="{{ filters.q }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Partner</label>
                        <select name="partner_id" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            {% for p in partners %}
                                <option value="{{ p.id }}" {{ filters.partner_id == p.id ? 'selected' : '' }}>{{ p.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Állapot</label>
                        <select name="status" class="form-select form-select-sm">
                            <option value="">Mind</option>
                            <option value="confirmed" {{ filters.status == 'confirmed' ? 'selected' : '' }}>Visszaigazolt</option>
                            <option value="invoiced" {{ filters.status == 'invoiced' ? 'selected' : '' }}>Számlázva</option>
                            <option value="cancelled" {{ filters.status == 'cancelled' ? 'selected' : '' }}>Törölve</option>
                        </select>
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Dátumtól</label>
                        <input type="date" name="date_from" class="form-control form-control-sm" value="{{ filters.date_from }}">
                    </div>
                    <div class="col-sm-3 col-lg-2">
                        <label class="form-label small text-muted mb-1">Dátumig</label>
                        <input type="date" name="date_to" class="form-control form-control-sm" value="{{ filters.date_to }}">
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                        <a href="{{ base_url }}/orders" class="btn btn-sm btn-outline-secondary">Törlés</a>
                    </div>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Rendelésszám</th>
                        <th>Partner</th>
                        <th>Dátum</th>
                        <th>Állapot</th>
                        <th class="text-end">Összeg</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for order in orders %}
                        <tr>
                            <td class="fw-medium">{{ order.order_number }}</td>
                            <td>{{ order.partner_name }}</td>
                            <td class="text-muted">{{ order.order_date }}</td>
                            <td>
                                {% if order.status == 'draft' %}
                                    <span class="badge rounded-pill text-bg-secondary">Piszkozat</span>
                                {% elseif order.status == 'confirmed' %}
                                    <span class="badge rounded-pill text-bg-primary">Visszaigazolt</span>
                                {% elseif order.status == 'invoiced' %}
                                    <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Számlázva</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Törölve</span>
                                {% endif %}
                            </td>
                            <td class="text-end">{{ order.total_amount|number_format(0, ',', ' ') }} Ft</td>
                            <td class="text-end">
                                <a href="{{ base_url }}/orders/{{ order.id }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő rendelés.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include 'common/pagination.twig' %}
        </div>
    </div>
{% endblock %}
