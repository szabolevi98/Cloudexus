{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Termékkategóriák</h2>
            <a href="{{ base_url }}/categories/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Új kategória
            </a>
        </div>
        <div class="cx-card__body p-0">
            <form method="get" class="p-3 border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-sm-4 col-lg-3">
                        <label class="form-label small text-muted mb-1">Keresés</label>
                        <input type="text" name="q" class="form-control form-control-sm" placeholder="Kategória neve…" value="{{ filters.q }}">
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                        <a href="{{ base_url }}/categories" class="btn btn-sm btn-outline-secondary">Törlés</a>
                    </div>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Név</th>
                        <th>Szülő kategória</th>
                        <th class="text-end">Termékek</th>
                        <th class="text-end">Műveletek</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for category in categories %}
                        <tr>
                            <td class="fw-medium">{{ category.name }}</td>
                            <td class="text-muted">{{ category.parent_name ?: '—' }}</td>
                            <td class="text-end">
                                <a href="{{ base_url }}/products?category_id={{ category.id }}" class="badge rounded-pill text-bg-primary text-decoration-none">
                                    {{ category.product_count }} db
                                </a>
                            </td>
                            <td class="text-end">
                                <a href="{{ base_url }}/categories/{{ category.id }}/edit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ base_url }}/categories/{{ category.id }}/delete" class="d-inline" onsubmit="return confirm('Biztosan törlöd?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="text-center text-muted py-4">Nincs a szűrésnek megfelelő kategória.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include 'common/pagination.twig' %}
        </div>
    </div>
{% endblock %}
