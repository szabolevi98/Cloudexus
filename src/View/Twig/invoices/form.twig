{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Új számla</h2>
        </div>
        <div class="cx-card__body">
            {% if from_order %}
                <div class="alert alert-info d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i>
                    A <strong>{{ from_order.order_number }}</strong> rendelés tételei előtöltve.
                </div>
            {% endif %}
            <form method="post" action="{{ base_url }}/invoices/create" id="invoice-form">
                {% if from_order %}
                    <input type="hidden" name="order_id" value="{{ from_order.id }}">
                {% endif %}
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Számlaszám</label>
                        <input type="text" name="invoice_number" class="form-control" value="{{ invoice_number }}" readonly>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label for="partner_id" class="form-label">Partner</label>
                        <select id="partner_id" name="partner_id" class="form-select" required>
                            <option value="">Válassz partnert…</option>
                            {% for p in partners %}
                                <option value="{{ p.id }}" {{ from_order and from_order.partner_id == p.id ? 'selected' : '' }}>{{ p.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Kiállítás dátuma</label>
                        <input type="date" name="issue_date" class="form-control" value="{{ "now"|date("Y-m-d") }}">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Fizetési határidő</label>
                        <input type="date" name="due_date" class="form-control" value="{{ "now"|date_modify("+8 days")|date("Y-m-d") }}">
                    </div>
                </div>

                {% include 'common/line-items.twig' with {
                    products: products,
                    prefill: from_order ? from_order.items|map(i => {product_id: i.product_id, quantity: i.quantity, unit_price: i.unit_price}) : []
                } %}

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="{{ base_url }}/invoices" class="btn btn-outline-secondary">Mégse</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Számla kiállítása
                    </button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
