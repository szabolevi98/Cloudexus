{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="cx-card">
                <div class="cx-card__header"><h2>Új teendő</h2></div>
                <div class="cx-card__body">
                    <form method="post" action="{{ base_url }}/todos/create">
                        <div class="mb-3">
                            <label for="title" class="form-label">Megnevezés</label>
                            <input type="text" id="title" name="title" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="due_date" class="form-label">Határidő</label>
                            <input type="date" id="due_date" name="due_date" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label for="partner_id" class="form-label">Partner <span class="text-muted small">(opcionális)</span></label>
                            <select id="partner_id" name="partner_id" class="form-select">
                                <option value="">— nincs —</option>
                                {% for p in partners %}
                                    <option value="{{ p.id }}">{{ p.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-4">
                            <label for="assigned_to" class="form-label">Felelős <span class="text-muted small">(opcionális)</span></label>
                            <select id="assigned_to" name="assigned_to" class="form-select">
                                <option value="">— nincs —</option>
                                {% for u in users %}
                                    <option value="{{ u.id }}">{{ u.full_name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg me-1"></i>Hozzáadás</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="cx-card">
                <div class="cx-card__header"><h2>Teendők</h2></div>
                <div class="cx-card__body p-0">
                    <form method="get" class="p-3 border-bottom">
                        <div class="row g-2 align-items-end">
                            <div class="col-sm-5">
                                <label class="form-label small text-muted mb-1">Keresés</label>
                                <input type="text" name="q" class="form-control form-control-sm" value="{{ filters.q }}">
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label small text-muted mb-1">Állapot</label>
                                <select name="status" class="form-select form-select-sm">
                                    <option value="">Mind</option>
                                    <option value="open" {{ filters.status == 'open' ? 'selected' : '' }}>Nyitott</option>
                                    <option value="done" {{ filters.status == 'done' ? 'selected' : '' }}>Kész</option>
                                </select>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Szűrés</button>
                            </div>
                        </div>
                    </form>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 cx-table">
                            <tbody>
                            {% for todo in todos %}
                                <tr>
                                    <td style="width:120px;">
                                        <form method="post" action="{{ base_url }}/todos/{{ todo.id }}/toggle">
                                            <input type="hidden" name="return" value="/todos?{{ filters|url_encode }}">
                                            {% if todo.is_done %}
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Visszaállítás nyitottra">
                                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Újranyit
                                                </button>
                                            {% else %}
                                                <button type="submit" class="btn btn-sm btn-success" title="Késznek jelölés">
                                                    <i class="bi bi-check-lg me-1"></i>Kész
                                                </button>
                                            {% endif %}
                                        </form>
                                    </td>
                                    <td>
                                        <div class="{{ todo.is_done ? 'text-decoration-line-through text-muted' : 'fw-medium' }}">{{ todo.title }}</div>
                                        <div class="small text-muted">
                                            {% if todo.partner_name %}<i class="bi bi-person me-1"></i>{{ todo.partner_name }}{% endif %}
                                            {% if todo.assigned_name %} · <i class="bi bi-person-badge me-1"></i>{{ todo.assigned_name }}{% endif %}
                                        </div>
                                    </td>
                                    <td class="text-end" style="width:130px;">
                                        {% if todo.due_date %}
                                            {% if not todo.is_done and todo.due_date < today %}
                                                <span class="badge rounded-pill text-bg-danger">{{ todo.due_date }}</span>
                                            {% else %}
                                                <span class="text-muted small">{{ todo.due_date }}</span>
                                            {% endif %}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end" style="width:56px;">
                                        <form method="post" action="{{ base_url }}/todos/{{ todo.id }}/delete" onsubmit="return confirm('Törlöd a teendőt?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td class="text-center text-muted py-4">Nincs a szűrésnek megfelelő teendő.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% include 'common/pagination.twig' %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
