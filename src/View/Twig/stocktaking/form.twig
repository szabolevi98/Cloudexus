{% extends 'common/layout.twig' %}

{% block content %}
    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Új leltár</h2>
        </div>
        <div class="cx-card__body">
            {# 1. lépés: raktárválasztás (GET) #}
            <form method="get" action="{{ base_url }}/stocktaking/create" class="row g-2 align-items-end mb-2">
                <div class="col-sm-5 col-lg-4">
                    <label for="warehouse_id" class="form-label">Raktár</label>
                    <select id="warehouse_id" name="warehouse_id" class="form-select" onchange="this.form.submit()">
                        <option value="">Válassz raktárat…</option>
                        {% for w in warehouses %}
                            <option value="{{ w.id }}" {{ warehouse_id == w.id ? 'selected' : '' }}>{{ w.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-secondary">Leltárív betöltése</button>
                </div>
            </form>
        </div>

        {% if warehouse_id and sheet %}
            {# 2. lépés: a leltárív kitöltése és könyvelése (POST) #}
            <form method="post" action="{{ base_url }}/stocktaking/create">
                <input type="hidden" name="warehouse_id" value="{{ warehouse_id }}">
                <div class="cx-card__body pt-0">
                    <div class="mb-3">
                        <label for="note" class="form-label">Megjegyzés</label>
                        <input type="text" id="note" name="note" class="form-control" placeholder="pl. Év végi leltár">
                    </div>
                    <p class="text-muted small">Írd be a ténylegesen megszámolt mennyiséget. Az üresen hagyott sorokat kihagyjuk. Az eltéréseket a rendszer készletkorrekcióként könyveli.</p>
                </div>
                <div class="table-responsive">
                    <table class="table cx-table align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Cikkszám</th>
                            <th>Megnevezés</th>
                            <th class="text-end">Könyv szerint</th>
                            <th class="text-end" style="width:160px;">Megszámolt</th>
                            <th class="text-end" style="width:120px;">Eltérés</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for row in sheet %}
                            <tr>
                                <td class="fw-medium">{{ row.sku }}
                                    <input type="hidden" name="product_id[]" value="{{ row.product_id }}">
                                    <input type="hidden" name="book_quantity[]" value="{{ row.book_quantity }}">
                                </td>
                                <td>{{ row.product_name }}</td>
                                <td class="text-end cx-book" data-book="{{ row.book_quantity }}">{{ row.book_quantity|number_format(0, ',', ' ') }} {{ row.unit }}</td>
                                <td class="text-end">
                                    <input type="number" step="0.001" name="counted_quantity[]" class="form-control form-control-sm text-end cx-counted" placeholder="—">
                                </td>
                                <td class="text-end cx-diff text-muted">—</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="cx-card__body d-flex justify-content-between align-items-center">
                    <a href="{{ base_url }}/stocktaking" class="btn btn-outline-secondary">Mégse</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Leltár könyvelése</button>
                </div>
            </form>
        {% elseif warehouse_id %}
            <div class="cx-card__body text-muted">Ebben a raktárban nincs aktív termék a leltározáshoz.</div>
        {% endif %}
    </div>

    <script>
        document.querySelectorAll('.cx-counted').forEach((input) => {
            input.addEventListener('input', () => {
                const row = input.closest('tr');
                const book = parseFloat(row.querySelector('.cx-book').dataset.book) || 0;
                const diffCell = row.querySelector('.cx-diff');
                if (input.value === '') {
                    diffCell.textContent = '—';
                    diffCell.className = 'text-end cx-diff text-muted';
                    return;
                }
                const diff = (parseFloat(input.value) || 0) - book;
                diffCell.textContent = (diff > 0 ? '+' : '') + new Intl.NumberFormat('hu-HU').format(diff);
                diffCell.className = 'text-end cx-diff fw-medium ' + (diff === 0 ? 'text-muted' : (diff > 0 ? 'text-success' : 'text-danger'));
            });
        });
    </script>
{% endblock %}
