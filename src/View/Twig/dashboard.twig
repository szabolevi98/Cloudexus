{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--primary">
                <div class="cx-stat__icon"><i class="bi bi-cart-check"></i></div>
                <div>
                    <div class="cx-stat__label">Vevői rendelés (10 nap)</div>
                    <div class="cx-stat__value">{{ orders_total_value|default(0)|number_format(0, ',', ' ') }} Ft</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--warning">
                <div class="cx-stat__icon"><i class="bi bi-hourglass-split"></i></div>
                <div>
                    <div class="cx-stat__label">Kintlevőség</div>
                    <div class="cx-stat__value">{{ outstanding_total|default(0)|number_format(0, ',', ' ') }} Ft</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--danger">
                <div class="cx-stat__icon"><i class="bi bi-exclamation-circle"></i></div>
                <div>
                    <div class="cx-stat__label">Kötelezettség</div>
                    <div class="cx-stat__value">{{ payable_total|default(0)|number_format(0, ',', ' ') }} Ft</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--success">
                <div class="cx-stat__icon"><i class="bi bi-box-seam"></i></div>
                <div>
                    <div class="cx-stat__label">Termékek</div>
                    <div class="cx-stat__value">{{ product_count|default(0) }} db</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Vevői rendelések</h2>
                    <span class="text-muted small">Elmúlt 10 nap</span>
                </div>
                <div class="cx-card__body">
                    <canvas id="orders-chart" height="90"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Teendők</h2>
                </div>
                <div class="cx-card__body text-center text-muted py-5">
                    <i class="bi bi-check2-square fs-1 d-block mb-2"></i>
                    Nincs elmaradt teendőd.
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        const dailyOrders = {{ daily_orders|default([])|json_encode|raw }};
        const ctx = document.getElementById('orders-chart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: dailyOrders.map(d => d.date.slice(5).replace('-', '.')),
                datasets: [{
                    label: 'Rendelés érték (Ft)',
                    data: dailyOrders.map(d => d.total_value),
                    borderColor: '#4f5bd5',
                    backgroundColor: 'rgba(79, 91, 213, 0.12)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 3,
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { callback: (v) => new Intl.NumberFormat('hu-HU').format(v) } }
                }
            }
        });
    </script>
{% endblock %}
