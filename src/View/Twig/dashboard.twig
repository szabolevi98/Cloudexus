{% extends 'common/layout.twig' %}

{% block content %}
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--primary">
                <div class="cx-stat__icon"><i class="bi bi-cart-check"></i></div>
                <div>
                    <div class="cx-stat__label">Vevői rendelés (10 nap)</div>
                    <div class="cx-stat__value">{{ orders_total_value|default(0)|number_format(0, ',', ' ') }} Ft</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--warning">
                <div class="cx-stat__icon"><i class="bi bi-hourglass-split"></i></div>
                <div>
                    <div class="cx-stat__label">Kintlevőség</div>
                    <div class="cx-stat__value">{{ outstanding.total|default(0)|number_format(0, ',', ' ') }} Ft</div>
                    {% if outstanding.overdue > 0 %}
                        <a href="{{ base_url }}/invoices?status=overdue" class="small text-danger text-decoration-none">Lejárt: {{ outstanding.overdue|number_format(0, ',', ' ') }} Ft</a>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--danger">
                <div class="cx-stat__icon"><i class="bi bi-exclamation-circle"></i></div>
                <div>
                    <div class="cx-stat__label">Kötelezettség</div>
                    <div class="cx-stat__value">{{ payable.total|default(0)|number_format(0, ',', ' ') }} Ft</div>
                    {% if payable.overdue > 0 %}
                        <a href="{{ base_url }}/incoming-invoices?status=overdue" class="small text-danger text-decoration-none">Lejárt: {{ payable.overdue|number_format(0, ',', ' ') }} Ft</a>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="cx-stat cx-stat--success">
                <div class="cx-stat__icon"><i class="bi bi-box-seam"></i></div>
                <div>
                    <div class="cx-stat__label">Termékek</div>
                    <div class="cx-stat__value">{{ product_count|default(0) }} db</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Vevői rendelések</h2>
                    <span class="text-muted small">Elmúlt 10 nap</span>
                </div>
                <div class="cx-card__body">
                    <canvas id="orders-chart" height="90"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="cx-card">
                <div class="cx-card__header">
                    <h2>Top kategóriák</h2>
                    <span class="text-muted small">30 nap</span>
                </div>
                <div class="cx-card__body">
                    {% for cat in top_categories %}
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="fw-medium">{{ cat.name }}</span>
                                <span class="text-muted">{{ cat.value|number_format(0, ',', ' ') }} Ft</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar" style="width: {{ top_categories_max > 0 ? (cat.value / top_categories_max * 100)|round : 0 }}%; background: var(--cx-primary);"></div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-tags fs-1 d-block mb-2"></i>
                            Még nincs értékesítési adat.
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <div class="cx-card">
        <div class="cx-card__header">
            <h2>Legutóbbi számlák</h2>
            <a href="{{ base_url }}/invoices" class="btn btn-sm btn-outline-secondary">Összes számla</a>
        </div>
        <div class="cx-card__body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 cx-table">
                    <thead>
                    <tr>
                        <th>Számlaszám</th>
                        <th>Partner</th>
                        <th>Kiállítás</th>
                        <th>Fizetési határidő</th>
                        <th>Állapot</th>
                        <th class="text-end">Összeg</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for invoice in recent_invoices %}
                        <tr>
                            <td><a href="{{ base_url }}/invoices/{{ invoice.id }}" class="fw-medium">{{ invoice.invoice_number }}</a></td>
                            <td>{{ invoice.partner_name }}</td>
                            <td class="text-muted">{{ invoice.issue_date }}</td>
                            <td class="text-muted">{{ invoice.due_date }}</td>
                            <td>
                                {% if invoice.status == 'unpaid' and invoice.due_date < today %}
                                    <span class="badge rounded-pill text-bg-danger">Lejárt</span>
                                {% elseif invoice.status == 'unpaid' %}
                                    <span class="badge rounded-pill text-bg-warning-subtle text-warning-emphasis">Fizetésre vár</span>
                                {% elseif invoice.status == 'paid' %}
                                    <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis">Kifizetve</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-danger-subtle text-danger-emphasis">Stornózva</span>
                                {% endif %}
                            </td>
                            <td class="text-end">{{ invoice.total_amount|number_format(0, ',', ' ') }} Ft</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="text-center text-muted py-4">Még nincs számla.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        const dailyOrders = {{ daily_orders|default([])|json_encode|raw }};
        const ctx = document.getElementById('orders-chart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: dailyOrders.map(d => d.date.slice(5).replace('-', '.')),
                datasets: [{
                    label: 'Rendelés érték (Ft)',
                    data: dailyOrders.map(d => d.total_value),
                    borderColor: '#4f5bd5',
                    backgroundColor: 'rgba(79, 91, 213, 0.12)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 3,
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { callback: (v) => new Intl.NumberFormat('hu-HU').format(v) } }
                }
            }
        });
    </script>
{% endblock %}
