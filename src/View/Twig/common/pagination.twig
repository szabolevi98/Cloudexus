{% if pager.total > 0 %}
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 px-3 py-2 border-top">
        <span class="text-muted small">{{ pager.from }}–{{ pager.to }} / {{ pager.total }} találat</span>
        {% if pager.pages > 1 %}
            {% set start = max(1, pager.page - 2) %}
            {% set end = min(pager.pages, pager.page + 2) %}
            <nav aria-label="Lapozás">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item {{ pager.page <= 1 ? 'disabled' : '' }}">
                        <a class="page-link" href="?{{ pager.filters|merge({page: pager.page - 1})|url_encode }}">&laquo;</a>
                    </li>
                    {% if start > 1 %}
                        <li class="page-item"><a class="page-link" href="?{{ pager.filters|merge({page: 1})|url_encode }}">1</a></li>
                        {% if start > 2 %}
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        {% endif %}
                    {% endif %}
                    {% for p in start..end %}
                        <li class="page-item {{ p == pager.page ? 'active' : '' }}">
                            <a class="page-link" href="?{{ pager.filters|merge({page: p})|url_encode }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    {% if end < pager.pages %}
                        {% if end < pager.pages - 1 %}
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        {% endif %}
                        <li class="page-item"><a class="page-link" href="?{{ pager.filters|merge({page: pager.pages})|url_encode }}">{{ pager.pages }}</a></li>
                    {% endif %}
                    <li class="page-item {{ pager.page >= pager.pages ? 'disabled' : '' }}">
                        <a class="page-link" href="?{{ pager.filters|merge({page: pager.page + 1})|url_encode }}">&raquo;</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    </div>
{% endif %}
