<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title|default('Cloudexus') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ base_url }}/assets/css/app.css">
</head>
<body>
<div class="cx-shell">
    <aside class="cx-sidebar">
        <div class="cx-sidebar__brand">
            <span class="cx-sidebar__brand-icon"><i class="bi bi-boxes"></i></span>
            <span class="cx-sidebar__brand-text">Cloudexus</span>
        </div>

        <nav class="cx-nav">
            <a class="cx-nav__link {{ active_menu == 'dashboard' ? 'is-active' : '' }}" href="{{ base_url }}/dashboard">
                <i class="bi bi-speedometer2"></i><span>Vezérlőpult</span>
            </a>

            <div class="cx-nav__group-label">Törzsadatok</div>
            <a class="cx-nav__link {{ active_menu == 'products' ? 'is-active' : '' }}" href="{{ base_url }}/products">
                <i class="bi bi-box-seam"></i><span>Termékek</span>
            </a>
            <a class="cx-nav__link {{ active_menu == 'categories' ? 'is-active' : '' }}" href="{{ base_url }}/categories">
                <i class="bi bi-tags"></i><span>Kategóriák</span>
            </a>
            <a class="cx-nav__link {{ active_menu == 'partners' ? 'is-active' : '' }}" href="{{ base_url }}/partners">
                <i class="bi bi-people"></i><span>Partnerek</span>
            </a>

            <div class="cx-nav__group-label">Készletkezelés</div>
            <a class="cx-nav__link {{ active_menu == 'warehouses' ? 'is-active' : '' }}" href="{{ base_url }}/warehouses">
                <i class="bi bi-building"></i><span>Raktárak</span>
            </a>
            <a class="cx-nav__link {{ active_menu == 'stock-in' ? 'is-active' : '' }}" href="{{ base_url }}/stock/in">
                <i class="bi bi-box-arrow-in-down"></i><span>Raktári bevét</span>
            </a>
            <a class="cx-nav__link {{ active_menu == 'stock-out' ? 'is-active' : '' }}" href="{{ base_url }}/stock/out">
                <i class="bi bi-box-arrow-up"></i><span>Raktári kiadás</span>
            </a>
            <a class="cx-nav__link {{ active_menu == 'stock-overview' ? 'is-active' : '' }}" href="{{ base_url }}/stock">
                <i class="bi bi-bar-chart-steps"></i><span>Raktárkészlet</span>
            </a>

            <div class="cx-nav__group-label">Értékesítés</div>
            <a class="cx-nav__link {{ active_menu == 'orders' ? 'is-active' : '' }}" href="{{ base_url }}/orders">
                <i class="bi bi-cart-check"></i><span>Vevői rendelések</span>
            </a>
            <a class="cx-nav__link {{ active_menu == 'invoices' ? 'is-active' : '' }}" href="{{ base_url }}/invoices">
                <i class="bi bi-receipt"></i><span>Számlázás</span>
            </a>

            <div class="cx-nav__group-label">Beszerzés</div>
            <a class="cx-nav__link {{ active_menu == 'purchase-orders' ? 'is-active' : '' }}" href="{{ base_url }}/purchase-orders">
                <i class="bi bi-truck"></i><span>Szállítói rendelések</span>
            </a>

            <div class="cx-nav__group-label">Pénztár</div>
            <a class="cx-nav__link {{ active_menu == 'cash' ? 'is-active' : '' }}" href="{{ base_url }}/cash">
                <i class="bi bi-cash-coin"></i><span>Pénztárbizonylat</span>
            </a>

            {% if auth_is_admin %}
                <div class="cx-nav__group-label">Beállítások</div>
                <a class="cx-nav__link {{ active_menu == 'users' ? 'is-active' : '' }}" href="{{ base_url }}/users">
                    <i class="bi bi-person-gear"></i><span>Felhasználók</span>
                </a>
            {% endif %}
        </nav>
    </aside>

    <div class="cx-main">
        <header class="cx-topbar">
            <button class="cx-topbar__toggle d-lg-none" type="button" aria-label="Menü">
                <i class="bi bi-list"></i>
            </button>
            <h1 class="cx-topbar__title">{{ page_title|default('') }}</h1>

            {% if auth_user_id %}
                <div class="dropdown ms-auto">
                    <button class="cx-user-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="cx-user-pill__avatar">{{ auth_user_name|slice(0, 1)|upper }}</span>
                        <span class="cx-user-pill__name">{{ auth_user_name }}</span>
                        <i class="bi bi-chevron-down"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li><a class="dropdown-item" href="{{ base_url }}/logout"><i class="bi bi-box-arrow-right me-2"></i>Kilépés</a></li>
                    </ul>
                </div>
            {% endif %}
        </header>

        <main class="cx-content">
            {% for type, message in flashes|default([]) %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : 'success' }} d-flex align-items-center shadow-sm" role="alert">
                    <i class="bi {{ type == 'error' ? 'bi-exclamation-triangle' : 'bi-check-circle' }} me-2"></i>
                    {{ message }}
                </div>
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.querySelector('.cx-topbar__toggle')?.addEventListener('click', function () {
        document.querySelector('.cx-sidebar').classList.toggle('is-open');
    });
</script>
</body>
</html>
